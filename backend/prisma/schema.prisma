generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// AUTH & USERS
// ═══════════════════════════════════════

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String?
  displayName   String?
  bio           String?
  avatar        String?
  cover         String?
  website       String?
  location      String?
  role          Role     @default(DESIGNER)
  isVerified    Boolean  @default(false)
  isBanned      Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  provider      AuthProvider @default(LOCAL)
  providerId    String?

  skills        String[] @default([])
  specialization String[] @default([])
  languages     String[] @default([])
  birthDate     DateTime?
  socialLinks   Json?    // { twitter, instagram, dribbble, linkedin, github }
  notificationPrefs Json? // { likes: true, comments: true, follows: true, messages: true }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  projects      Project[]
  likes         Like[]
  comments      Comment[]
  collections   Collection[]
  followers     Follow[]   @relation("following")
  following     Follow[]   @relation("follower")
  sentMessages     Message[]  @relation("sender")
  receivedMessages Message[]  @relation("receiver")
  notifications    Notification[] @relation("recipient")
  notificationsCreated Notification[] @relation("actor")
  challengeEntries ChallengeEntry[]
  reports       Report[]   @relation("reporter")
  reportedReports Report[] @relation("reported")
  sessions      Session[]
  passwordResets PasswordReset[]
  blogPosts     BlogPost[]
  jobs          Job[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

enum Role {
  DESIGNER
  STUDIO
  RECRUITER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// ═══════════════════════════════════════
// PROJECTS
// ═══════════════════════════════════════

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  cover       String   // URL to cover image
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)

  // Trending score (updated by cron)
  trendScore  Float    @default(0)

  // Metadata
  tags        String[] @default([])
  tools       String[] @default([])
  colors      String[] @default([]) // hex values

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  media       ProjectMedia[]
  likes       Like[]
  comments    Comment[]
  collectionItems CollectionItem[]
  challengeEntries ChallengeEntry[]

  @@index([authorId])
  @@index([categoryId])
  @@index([trendScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([featured])
  @@index([published])
}

model ProjectMedia {
  id        String    @id @default(cuid())
  url       String
  type      MediaType @default(IMAGE)
  order     Int       @default(0)
  width     Int?
  height    Int?
  
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum MediaType {
  IMAGE
  VIDEO
  EMBED
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  order    Int       @default(0)
  projects Project[]

  @@index([slug])
}

// ═══════════════════════════════════════
// SOCIAL
// ═══════════════════════════════════════

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Reply support
  parentId  String?
  parent    Comment? @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("replies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([parentId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ═══════════════════════════════════════
// COLLECTIONS
// ═══════════════════════════════════════

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  cover       String?
  isPrivate   Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, projectId])
  @@index([collectionId])
}

// ═══════════════════════════════════════
// CHALLENGES
// ═══════════════════════════════════════

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  rules       String?  @db.Text
  cover       String?
  deadline    DateTime
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     ChallengeEntry[]

  @@index([isActive])
  @@index([deadline])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  score       Float     @default(0) // calculated from project likes
  isWinner    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([score(sort: Desc)])
}

// ═══════════════════════════════════════
// MESSAGING
// ═══════════════════════════════════════

model Message {
  id         String   @id @default(cuid())
  content    String   @db.Text
  fileUrl    String?
  fileName   String?
  read       Boolean  @default(false)
  
  senderId   String
  sender     User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, read])
  @@index([createdAt(sort: Desc)])
}

// ═══════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  read        Boolean          @default(false)
  
  recipientId String
  recipient   User             @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User             @relation("actor", fields: [actorId], references: [id], onDelete: Cascade)
  
  // Polymorphic reference
  entityType  String?          // "project", "comment", "challenge"
  entityId    String?

  createdAt   DateTime         @default(now())

  @@index([recipientId, read])
  @@index([createdAt(sort: Desc)])
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
  CHALLENGE_WINNER
  SYSTEM
}

// ═══════════════════════════════════════
// MODERATION
// ═══════════════════════════════════════

model Report {
  id          String       @id @default(cuid())
  reason      String
  details     String?      @db.Text
  status      ReportStatus @default(PENDING)
  
  reporterId  String
  reporter    User         @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  reportedUserId String?
  reportedUser   User?     @relation("reported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  
  entityType  String?      // "project", "comment", "user"
  entityId    String?

  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ═══════════════════════════════════════
// ANALYTICS
// ═══════════════════════════════════════

model ProjectView {
  id        String   @id @default(cuid())
  projectId String
  viewerIp  String?
  userId    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// BLOG
// ═══════════════════════════════════════

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  excerpt     String?  @db.Text
  cover       String?
  published   Boolean  @default(true)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

// ═══════════════════════════════════════
// EVENTS
// ═══════════════════════════════════════

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  type        String   // TOP_CREATOR, NEW_FEATURE, MILESTONE
  entityType  String?  // "user", "project"
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

// ═══════════════════════════════════════
// JOBS
// ═══════════════════════════════════════

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  type        String   @default("FULL_TIME") // FULL_TIME, PART_TIME, FREELANCE, REMOTE
  description String   @db.Text
  salary      String?
  contactEmail String?
  contactUrl  String?
  published   Boolean  @default(true)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}
