{
  "expo": {
    "name": "Folio",
    "slug": "folio-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#6C5CE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.folio.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.folio.app"
    },
    "extra": {
      "apiBaseUrl": "https://folio-platform-folio.up.railway.app/api",
      "eas": {
        "projectId": "f657ea01-a88a-4ad3-b723-3a6e167ade14"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "owner": "hovakimian_design"
  }
}
